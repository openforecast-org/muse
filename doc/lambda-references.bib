% Note on the sigmoid (logistic) reparameterisation of lambda.
%
% There is no dedicated publication for "estimate lambda via a sigmoid".
% What `muse` does -- map an unconstrained optimiser variable theta to a
% box-constrained lambda via
%       lambda = lo + (hi - lo) * logistic(theta)
% -- is the standard lower-and-upper-bounded scalar reparameterisation used
% to turn a constrained optimisation/inference problem into an unconstrained
% one.  The canonical documented reference for this transform (with its
% Jacobian) is the Stan reference, Section "Lower and Upper Bounded Scalar".
@article{carpenter2017stan,
  author  = {Carpenter, Bob and Gelman, Andrew and Hoffman, Matthew D. and
             Lee, Daniel and Goodrich, Ben and Betancourt, Michael and
             Brubaker, Marcus A. and Guo, Jiqiang and Li, Peter and Riddell, Allen},
  title   = {Stan: A Probabilistic Programming Language},
  journal = {Journal of Statistical Software},
  year    = {2017},
  volume  = {76},
  number  = {1},
  pages   = {1--32},
  doi     = {10.18637/jss.v076.i01}
}
